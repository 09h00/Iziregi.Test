<Window x:Class="Iziregi.Test.WorkOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bon de régie"
        Width="530"
        Height="490"
        MinWidth="520"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        WindowState="Normal">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="16">
            <Grid.LayoutTransform>
                <ScaleTransform ScaleX="0.7" ScaleY="0.7"/>
            </Grid.LayoutTransform>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <Button Content="← Retour" Width="110" Click="Back_Click"/>
                <TextBlock x:Name="TitleTextBlock"
                           DockPanel.Dock="Right"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Right"/>
            </DockPanel>

            <!-- DEMANDE -->
            <Border x:Name="DemandBorder"
                    Grid.Row="1"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Background="#FAFAFA"
                    Margin="0,0,0,12">
                <StackPanel x:Name="DemandPanel">
                    <TextBlock Text="Demande" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Bat./Salle" VerticalAlignment="Center"/>
                        <ComboBox x:Name="PlaceComboBox" Grid.Row="0" Grid.Column="1" Margin="0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Demandé par" VerticalAlignment="Center"/>
                        <TextBox x:Name="RequestedByTextBox" Grid.Row="1" Grid.Column="1" Margin="0,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Effectué par" VerticalAlignment="Center"/>
                        <ComboBox x:Name="PerformedByComboBox" Grid.Row="2" Grid.Column="1" Margin="0,4"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Date" VerticalAlignment="Center"/>
                        <DatePicker x:Name="RequestDatePicker" Grid.Row="3" Grid.Column="1" Margin="0,4"/>
                    </Grid>

                    <TextBlock Text="Descriptif" FontWeight="SemiBold" Margin="0,12,0,6"/>
                    <TextBox x:Name="DescriptionTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="90"/>
                </StackPanel>
            </Border>

            <!-- DEVIS -->
            <Border x:Name="QuoteBorder"
                    Grid.Row="2"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Background="#FAFAFA"
                    Margin="0,0,0,12">
                <StackPanel x:Name="QuotePanel">

                    <DockPanel>
                        <TextBlock Text="Devis" FontSize="16" FontWeight="Bold" DockPanel.Dock="Left"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="AddMaterialLineButton"
                                    Content="+ Ajouter"
                                    Width="90"
                                    Click="AddMaterialLine_Click"/>
                            <Button x:Name="DeleteMaterialLineButton"
                                    Content="Effacer ligne"
                                    Width="120"
                                    Margin="8,0,0,0"
                                    Click="DeleteMaterialLine_Click"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Tableau -->
                    <DataGrid x:Name="LinesGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False"
                              Margin="0,10,0,0"
                              MinHeight="140">
                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Libellé"
                                                Binding="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                Width="*"/>

                            <!-- Qt -->
                            <DataGridTextColumn Header="Qt"
                                                Width="64"
                                                Binding="{Binding QtyDisplay, UpdateSourceTrigger=PropertyChanged}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>

                                <!-- ✅ IMPORTANT : supprime toute limite globale (MaxLength=2) -->
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="MaxLength" Value="0"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>

                            <!-- Prix/pc -->
                            <DataGridTextColumn Header="Prix/pc"
                                                Width="100"
                                                Binding="{Binding UnitPriceDisplay, UpdateSourceTrigger=PropertyChanged}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>

                                <!-- ✅ IMPORTANT : supprime toute limite globale (MaxLength=2) -->
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="MaxLength" Value="0"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>

                            <!-- Total -->
                            <DataGridTextColumn Header="Total"
                                                Width="100"
                                                IsReadOnly="True"
                                                Binding="{Binding LineTotal, StringFormat={}{0:0.00}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Montants (alignés sur Qt / Prix/pc / Total) -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Main d'œuvre (heures / prix-h)" VerticalAlignment="Center"/>
                        <TextBox x:Name="LaborHoursTextBox"
                                 Grid.Row="0" Grid.Column="1"
                                 Margin="6,2"
                                 TextAlignment="Right"
                                 Text="{Binding LaborHoursDisplay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox x:Name="LaborRateTextBox"
                                 Grid.Row="0" Grid.Column="2"
                                 Margin="6,2"
                                 TextAlignment="Right"
                                 Text="{Binding LaborRateDisplay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock x:Name="LaborTotalTextBlock"
                                   Grid.Row="0" Grid.Column="3"
                                   Margin="6,2"
                                   TextAlignment="Right"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Déplacements (qt / prix)" VerticalAlignment="Center"/>
                        <TextBox x:Name="TravelQtyTextBox"
                                 Grid.Row="1" Grid.Column="1"
                                 Margin="6,2"
                                 TextAlignment="Right"
                                 Text="{Binding TravelQtyDisplay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox x:Name="TravelRateTextBox"
                                 Grid.Row="1" Grid.Column="2"
                                 Margin="6,2"
                                 TextAlignment="Right"
                                 Text="{Binding TravelRateDisplay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock x:Name="TravelTotalTextBlock"
                                   Grid.Row="1" Grid.Column="3"
                                   Margin="6,2"
                                   TextAlignment="Right"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="TVA (%)" VerticalAlignment="Center"/>
                        <TextBox x:Name="TvaRateTextBox"
                                 Grid.Row="2" Grid.Column="1"
                                 Margin="6,2"
                                 TextAlignment="Right"
                                 Text="{Binding TvaRateDisplay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock x:Name="TvaAmountTextBlock"
                                   Grid.Row="2" Grid.Column="3"
                                   Margin="6,2"
                                   TextAlignment="Right"/>
                    </Grid>

                    <!-- Bas devis -->
                    <Border BorderBrush="#D6D6D6"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Background="White"
                            Margin="0,14,0,0">
                        <StackPanel>

                            <!-- Totaux -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="SaveQuoteButton"
                                        Grid.Column="0"
                                        Content="Enregistrer le devis"
                                        Width="160"
                                        Click="SaveQuote_Click"/>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock x:Name="TotalHtTextBlock" FontWeight="SemiBold" TextAlignment="Right"/>
                                    <TextBlock x:Name="TotalTtcTextBlock" FontWeight="SemiBold" TextAlignment="Right" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Ligne DOUBLE -->
                            <Grid Margin="0,12,0,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1"/>
                                    <RowDefinition Height="5"/>
                                    <RowDefinition Height="1"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#BDBDBD" Height="1"/>
                                <Border Grid.Row="2" Background="#BDBDBD" Height="1"/>
                            </Grid>

                            <!-- Remarque 65% + Envoyer 35% -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="13*"/>
                                    <ColumnDefinition Width="7*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Remarques" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="QuoteNotesTextBox"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Height="70"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <Button x:Name="SaveSignerReplyButton"
                                            Content="Envoyer le devis"
                                            Width="180"
                                            Click="SaveSignerReply_Click"
                                            Visibility="Collapsed"/>
                                    <Button x:Name="SignerExportPdfButton"
                                            Content="Exporter PDF"
                                            Width="180"
                                            Margin="0,8,0,0"
                                            Click="SignerExportPdf_Click"
                                            IsEnabled="False"
                                            Visibility="Collapsed"/>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- SIGNATURE -->
            <Border x:Name="SignatureBorder"
                    Grid.Row="3"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Background="#FAFAFA"
                    Margin="0,0,0,12">
                <StackPanel x:Name="SignaturePanel">
                    <TextBlock Text="Validation / Signature" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                </StackPanel>
            </Border>

            <!-- ACTIONS -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ExportForSignatureButton"
                        Content="Exporter pour signature"
                        Width="180"
                        Margin="0,0,8,0"
                        Click="ExportForSignature_Click"/>
                <Button x:Name="CreatePdfButton"
                        Content="Créer PDF"
                        Width="120"
                        Margin="0,0,8,0"
                        Click="CreatePdf_Click"/>
                <Button x:Name="SaveHeaderButton"
                        Content="Enregistrer Demande"
                        Width="160"
                        Click="SaveHeader_Click"/>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</Window>