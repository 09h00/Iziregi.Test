<!-- File: Pages/ListsPage.xaml -->
<UserControl x:Class="Iziregi.Test.Pages.ListsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- ✅ 4 colonnes côte à côte + 1 colonne “réserve”
         ✅ Boutons en bas : WrapPanel => si ça ne passe plus, ils se superposent automatiquement -->
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===================== -->
        <!-- Lieux -->
        <!-- ===================== -->
        <GroupBox Header="Lieux" Grid.Column="0">
            <DockPanel>

                <!-- Par défaut (bouton en dessous) -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="#E2E2E2"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Background="#FAFAFA"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Par défaut :" Margin="0,0,0,6"/>
                        <ComboBox x:Name="DefaultPlaceComboBox"
                                  IsEditable="True"
                                  Margin="0,0,0,8"/>
                        <Button Content="Définir"
                                Width="90"
                                HorizontalAlignment="Left"
                                Click="SetDefaultPlace_Click"/>
                    </StackPanel>
                </Border>

                <!-- Actions (en bas) -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#E2E2E2"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Background="#FFFFFF"
                        Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Nouveau :" Margin="0,0,0,6"/>
                        <TextBox x:Name="NewPlaceTextBox" Margin="0,0,0,10"/>

                        <WrapPanel>
                            <Button Content="Ajouter" Width="85" Margin="0,0,8,8" Click="AddPlace_Click"/>
                            <Button Content="Renommer" Width="85" Margin="0,0,8,8" Click="RenamePlace_Click"/>
                            <Button Content="Supprimer" Width="85" Margin="0,0,8,8" Click="DeletePlace_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <ListBox x:Name="PlacesListBox"/>
            </DockPanel>
        </GroupBox>

        <!-- ===================== -->
        <!-- Entreprises -->
        <!-- ===================== -->
        <GroupBox Header="Entreprises" Grid.Column="2">
            <DockPanel>

                <Border DockPanel.Dock="Top"
                        BorderBrush="#E2E2E2"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Background="#FAFAFA"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Par défaut :" Margin="0,0,0,6"/>
                        <ComboBox x:Name="DefaultCompanyComboBox"
                                  IsEditable="True"
                                  Margin="0,0,0,8"/>
                        <Button Content="Définir"
                                Width="90"
                                HorizontalAlignment="Left"
                                Click="SetDefaultCompany_Click"/>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#E2E2E2"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Background="#FFFFFF"
                        Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Nouveau :" Margin="0,0,0,6"/>
                        <TextBox x:Name="NewCompanyTextBox" Margin="0,0,0,10"/>

                        <WrapPanel>
                            <Button Content="Ajouter" Width="85" Margin="0,0,8,8" Click="AddCompany_Click"/>
                            <Button Content="Renommer" Width="85" Margin="0,0,8,8" Click="RenameCompany_Click"/>
                            <Button Content="Supprimer" Width="85" Margin="0,0,8,8" Click="DeleteCompany_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <ListBox x:Name="CompaniesListBox"/>
            </DockPanel>
        </GroupBox>

        <!-- ===================== -->
        <!-- Demandé par -->
        <!-- ===================== -->
        <GroupBox Header="Demandé par" Grid.Column="4">
            <DockPanel>

                <Border DockPanel.Dock="Top"
                        BorderBrush="#E2E2E2"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Background="#FAFAFA"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Par défaut :" Margin="0,0,0,6"/>
                        <ComboBox x:Name="DefaultRequesterComboBox"
                                  IsEditable="True"
                                  Margin="0,0,0,8"/>
                        <Button Content="Définir"
                                Width="90"
                                HorizontalAlignment="Left"
                                Click="SetDefaultRequester_Click"/>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#E2E2E2"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Background="#FFFFFF"
                        Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Nouveau :" Margin="0,0,0,6"/>
                        <TextBox x:Name="NewRequesterTextBox" Margin="0,0,0,10"/>

                        <WrapPanel>
                            <Button Content="Ajouter" Width="85" Margin="0,0,8,8" Click="AddRequester_Click"/>
                            <Button Content="Renommer" Width="85" Margin="0,0,8,8" Click="RenameRequester_Click"/>
                            <Button Content="Supprimer" Width="85" Margin="0,0,8,8" Click="DeleteRequester_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <ListBox x:Name="RequestersListBox"/>
            </DockPanel>
        </GroupBox>

        <!-- ===================== -->
        <!-- Réserve (4e colonne) -->
        <!-- ===================== -->
        <GroupBox Header="Réserve" Grid.Column="6">
            <DockPanel>

                <Border DockPanel.Dock="Top"
                        BorderBrush="#E2E2E2"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Background="#FAFAFA"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Par défaut :" Margin="0,0,0,6"/>
                        <ComboBox IsEditable="True" Margin="0,0,0,8" IsEnabled="False"/>
                        <Button Content="Définir" Width="90" HorizontalAlignment="Left" IsEnabled="False"/>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#E2E2E2"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8"
                        Background="#FFFFFF"
                        Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Nouveau :" Margin="0,0,0,6"/>
                        <TextBox Margin="0,0,0,10" IsEnabled="False"/>

                        <WrapPanel>
                            <Button Content="Ajouter" Width="85" Margin="0,0,8,8" IsEnabled="False"/>
                            <Button Content="Renommer" Width="85" Margin="0,0,8,8" IsEnabled="False"/>
                            <Button Content="Supprimer" Width="85" Margin="0,0,8,8" IsEnabled="False"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <ListBox IsEnabled="False">
                    <ListBoxItem Foreground="Gray">Colonne en réserve</ListBoxItem>
                </ListBox>

            </DockPanel>
        </GroupBox>

    </Grid>
</UserControl>