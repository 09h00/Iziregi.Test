<!-- File: Pages/TrashPage.xaml -->
<UserControl x:Class="Iziregi.Test.Pages.TrashPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <DockPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Corbeille" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>

            <Button Content="Restaurer (sélection)"
                    Width="180"
                    Margin="16,0,0,0"
                    Click="RestoreSelected_Click"/>

            <Button Content="Supprimer définitivement (sélection)"
                    Width="260"
                    Margin="8,0,0,0"
                    Click="DeleteSelected_Click"/>

            <Button Content="Rafraîchir" Width="120" Margin="16,0,0,0" Click="Refresh_Click"/>
        </StackPanel>

        <DataGrid x:Name="TrashedGrid"
                  Style="{StaticResource IziregiGrid}"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  ColumnWidth="SizeToHeader">

            <DataGrid.Columns>

                <!-- Sélection via cases à cocher -->
                <DataGridTemplateColumn Width="42" IsReadOnly="False">
                    <DataGridTemplateColumn.Header>
                        <CheckBox x:Name="SelectAllCheckBox"
                                  ToolTip="Tout cocher / décocher"
                                  Click="SelectAllCheckBox_Click"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </DataGridTemplateColumn.Header>

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="N° Bdr" Binding="{Binding WorkOrder.BdrNumber}" Width="80" IsReadOnly="True"/>
                <DataGridTextColumn Header="Bat./Salle" Binding="{Binding WorkOrder.Place}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Date"
                                    Binding="{Binding WorkOrder.RequestDate, StringFormat=dd.MM.yyyy}"
                                    Width="105"
                                    IsReadOnly="True"/>

                <DataGridTemplateColumn Header="Demandé par" MinWidth="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource IziregiGridTextCell}"
                                       Text="{Binding WorkOrder.RequestedBy}"
                                       ToolTip="{Binding WorkOrder.RequestedBy}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Effectué par" MinWidth="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource IziregiGridTextCell}"
                                       Text="{Binding WorkOrder.PerformedBy}"
                                       ToolTip="{Binding WorkOrder.PerformedBy}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- ✅ Ajouts demandés -->
                <DataGridCheckBoxColumn Header="Validé"
                                        Binding="{Binding WorkOrder.IsValidated}"
                                        Width="80"
                                        IsReadOnly="True"/>

                <DataGridCheckBoxColumn Header="Effectué"
                                        Binding="{Binding WorkOrder.IsPerformed}"
                                        Width="90"
                                        IsReadOnly="True"/>

                <DataGridTextColumn Header="Mis à la corbeille le"
                                    Binding="{Binding WorkOrder.TrashedAt, StringFormat=dd.MM.yyyy}"
                                    Width="140"
                                    IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</UserControl>