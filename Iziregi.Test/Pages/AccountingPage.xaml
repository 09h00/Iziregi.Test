<!-- File: Pages/AccountingPage.xaml -->
<UserControl x:Class="Iziregi.Test.Pages.AccountingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <DockPanel>

        <!-- Header + filtres -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Comptabilité"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <Button Content="Rafraîchir"
                        Width="120"
                        Margin="16,0,0,0"
                        Click="Refresh_Click"/>

                <Button Content="Exporter CSV (détail)"
                        Width="190"
                        Margin="8,0,0,0"
                        Click="ExportDetailsCsv_Click"/>

                <Button Content="Exporter CSV (totaux entreprises)"
                        Width="260"
                        Margin="8,0,0,0"
                        Click="ExportCompaniesCsv_Click"/>
            </StackPanel>

            <Border BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10"
                    Background="#FAFAFA"
                    Margin="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="20"/>

                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="20"/>

                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="20"/>

                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Du" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker x:Name="FromDatePicker" Grid.Column="1"/>

                    <TextBlock Grid.Column="3" Text="Au" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker x:Name="ToDatePicker" Grid.Column="4"/>

                    <TextBlock Grid.Column="6" Text="Entreprise" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CompanyFilterComboBox"
                              Grid.Column="7"
                              IsEditable="False"
                              SelectionChanged="Filters_Changed"/>

                    <TextBlock Grid.Column="9" Text="Projet" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="ProjectFilterComboBox"
                              Grid.Column="10"
                              IsEditable="False"
                              SelectionChanged="Filters_Changed"/>
                </Grid>
            </Border>

        </StackPanel>

        <!-- Body -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Total général -->
            <Border Grid.Row="0"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Background="#FAFAFA">
                <StackPanel>
                    <TextBlock Text="Total général (HT / TVA / TTC)"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="HT : " FontWeight="SemiBold"/>
                        <TextBlock x:Name="TotalHtTextBlock" Width="120"/>

                        <TextBlock Text="TVA : " FontWeight="SemiBold" Margin="16,0,0,0"/>
                        <TextBlock x:Name="TotalTvaTextBlock" Width="120"/>

                        <TextBlock Text="TTC : " FontWeight="SemiBold" Margin="16,0,0,0"/>
                        <TextBlock x:Name="TotalTtcTextBlock" Width="120" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ✅ Gauche: totaux + détail | Droite: graphique (50/50) -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <!-- ✅ moitié / moitié -->
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Colonne gauche : Totaux + Détail -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Totaux par entreprises -->
                    <Border Grid.Row="0"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Background="White">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Totaux par entreprises"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <DataGrid x:Name="ByCompanyGrid"
                                      Style="{StaticResource IziregiGrid}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      ColumnWidth="Auto"
                                      CanUserResizeColumns="True"
                                      HeadersVisibility="Column"
                                      SelectionChanged="ByCompanyGrid_SelectionChanged">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.Columns>

                                    <DataGridTextColumn Header="Entreprises"
                                                        Binding="{Binding Company}"
                                                        Width="140"/>

                                    <DataGridTextColumn Header="Nb de bons"
                                                        Binding="{Binding Count}"
                                                        Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="HT"
                                                        Binding="{Binding TotalHt, StringFormat={}{0:0.00}}"
                                                        Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="TVA"
                                                        Binding="{Binding TotalTva, StringFormat={}{0:0.00}}"
                                                        Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="TTC"
                                                        Binding="{Binding TotalTtc, StringFormat={}{0:0.00}}"
                                                        Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- Détail des bons -->
                    <Border Grid.Row="2"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Background="White">
                        <DockPanel>

                            <TextBlock x:Name="DetailsTitleTextBlock"
                                       DockPanel.Dock="Top"
                                       Text="Détail — sélectionne une entreprise"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <DataGrid x:Name="DetailsGrid"
                                      Style="{StaticResource IziregiGrid}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      ColumnWidth="Auto"
                                      HeadersVisibility="Column">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="BDR" Binding="{Binding Bdr}" Width="70"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="95"/>
                                    <DataGridTextColumn Header="Lieu" Binding="{Binding Place}" Width="110"/>

                                    <DataGridTextColumn Header="HT" Binding="{Binding Ht, StringFormat={}{0:0.00}}" Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="TVA" Binding="{Binding Tva, StringFormat={}{0:0.00}}" Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="TTC" Binding="{Binding Ttc, StringFormat={}{0:0.00}}" Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                        </DockPanel>
                    </Border>

                </Grid>

                <!-- Graphique à droite -->
                <Border Grid.Column="2"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Background="White">
                    <DockPanel>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="Graphique — Coûts TTC par entreprise"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer Grid.Row="0"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="ChartItems">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Width="55" Margin="0,0,4,0" VerticalAlignment="Bottom">
                                                <TextBlock Text="{Binding TotalTtc, StringFormat={}{0:0.00}}"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,0,0,4"/>
                                                <Border Height="{Binding BarHeight}"
                                                        Width="16"
                                                        CornerRadius="3"
                                                        Background="#3B82F6"
                                                        HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Company}"
                                                           FontSize="10"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock Grid.Row="1"
                                       Foreground="Gray"
                                       FontSize="11"
                                       Margin="0,10,0,0"
                                       Text="(barres resserrées pour tout voir)"/>
                        </Grid>

                    </DockPanel>
                </Border>

            </Grid>

        </Grid>

    </DockPanel>
</UserControl>