<!-- File: MainWindow.xaml -->
<Window x:Class="Iziregi.Test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Iziregi.Test"
        Title="Iziregi"
        Height="650"
        Width="1100"
        MinHeight="600"
        MinWidth="980"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- MENU NAVIGATION -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Tableau de bord" Click="NavDashboard_Click"/>
            <MenuItem Header="Comptabilité" Click="NavAccounting_Click"/>
            <MenuItem Header="Archives" Click="NavArchives_Click"/>
            <MenuItem Header="Corbeille" Click="NavTrash_Click"/>
            <MenuItem Header="Listes" Click="NavLists_Click"/>
        </Menu>

        <!-- CONTENU (PAGE) -->
        <Border Background="White" Padding="12">
            <ContentControl x:Name="MainContent"/>
        </Border>

    </DockPanel>
</Window>