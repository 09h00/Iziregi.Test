<Window x:Class="Iziregi.Test.ListsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Listes" Height="450" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Lieux -->
        <GroupBox Header="Lieux">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBox x:Name="NewPlaceTextBox" Width="240" Margin="0,0,8,0" />
                    <Button Content="Ajouter" Width="90" Click="AddPlace_Click"/>
                    <Button Content="Supprimer" Width="90" Margin="8,0,0,0" Click="DeletePlace_Click"/>
                </StackPanel>

                <ListBox x:Name="PlacesListBox"/>
            </DockPanel>
        </GroupBox>

        <!-- Entreprises -->
        <GroupBox Header="Entreprises" Grid.Column="2">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBox x:Name="NewCompanyTextBox" Width="240" Margin="0,0,8,0" />
                    <Button Content="Ajouter" Width="90" Click="AddCompany_Click"/>
                    <Button Content="Supprimer" Width="90" Margin="8,0,0,0" Click="DeleteCompany_Click"/>
                </StackPanel>

                <ListBox x:Name="CompaniesListBox"/>
            </DockPanel>
        </GroupBox>
    </Grid>
</Window>